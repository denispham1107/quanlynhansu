rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userDoc(request.auth.uid))
        && get(userDoc(request.auth.uid)).data.role == "admin";
    }

    function isEmployee() {
      return signedIn()
        && exists(userDoc(request.auth.uid))
        && get(userDoc(request.auth.uid)).data.role == "employee";
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if isAdmin()
        && request.resource.data.uid == userId
        && request.resource.data.role in ["admin", "employee"];
      allow update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /workOrders/{workOrderId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.assignedToUid == request.auth.uid);

      allow create: if isAdmin();

      // Nhân viên chỉ được báo hoàn thành công việc của chính mình.
      allow update: if isEmployee()
        && resource.data.assignedToUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "submittedAt"])
        && request.resource.data.status == "submitted";

      // Admin được duyệt, yêu cầu làm lại, xoá, thêm giờ và dời lịch công việc nối tiếp.
      allow update, delete: if isAdmin();
    }

    match /timeExtensionReasons/{reasonId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.recipientUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.recipientUid is string
        && request.resource.data.title is string
        && request.resource.data.message is string;

      allow update: if signedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"]);

      allow delete: if isAdmin()
        || (signedIn() && resource.data.recipientUid == request.auth.uid);
    }
  }
}
