rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userDoc(request.auth.uid))
        && get(userDoc(request.auth.uid)).data.role == "admin";
    }

    function isValidRole(role) {
      return role in ["admin", "employee"];
    }

    function isValidTaskStatus(status) {
      return status in ["waiting_assignee", "doing", "submitted", "completed", "redo", "overdue"];
    }

    function taskDoc(taskId) {
      return /databases/$(database)/documents/tasks/$(taskId);
    }

    function workOrderDoc(workOrderId) {
      return /databases/$(database)/documents/workOrders/$(workOrderId);
    }

    // Client tạo queueStartAt bằng thời gian trên máy người dùng, còn request.time
    // là thời gian server Firestore khi commit. Hai mốc này có thể lệch vài giây,
    // nếu bắt queueStartAt >= request.time tuyệt đối sẽ dễ bị lỗi
    // "Missing or insufficient permissions" khi tạo/giao việc ngay lập tức.
    function isValidQueueStartAt(value) {
      return value is timestamp
        && value >= request.time - duration.value(2, "m");
    }

    function isValidNotificationType(type) {
      return type in [
        "task_assigned",
        "task_assigned_admin",
        "task_submitted",
        "task_approved",
        "task_approved_admin",
        "task_redo",
        "task_time_extended",
        "task_time_extended_admin",
        "task_reassigned",
        "task_reassigned_removed",
        "task_reassigned_admin"
      ];
    }

    match /users/{userId} {
      // Admin đọc tất cả user; nhân viên chỉ đọc hồ sơ của chính mình.
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);

      // Admin tạo hồ sơ user sau khi tạo tài khoản bằng Firebase Auth.
      // Admin đầu tiên nên tạo thủ công theo hướng dẫn, trước khi bật rules chặt này.
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(["uid", "name", "email", "role", "createdByUid", "createdAt"])
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && isValidRole(request.resource.data.role)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdAt == request.time;

      // Chỉ Admin được sửa user. Không cho đổi uid/email gốc qua client.
      allow update: if isAdmin()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role in ["admin", "employee"];

      // Có thể xoá hồ sơ nhân viên, nhưng không cho Admin tự xoá chính mình từ client.
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /workOrders/{workOrderId} {
      // Admin đọc toàn bộ phiếu. Nhân viên cũng được đọc metadata phiếu
      // (tên phiếu, tổng số công việc) để tiêu đề phiếu hiển thị giống trang Admin.
      allow read: if isAdmin() || signedIn();

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "id",
          "name",
          "createdByUid",
          "createdByName",
          "createdAt",
          "taskCount",
          "status"
        ])
        && request.resource.data.id == workOrderId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.taskCount is int
        && request.resource.data.taskCount > 0
        && request.resource.data.status in ["draft", "dispatched"];

      // Chỉ cho phép chuyển từ "draft" (chưa giao việc) sang "dispatched" (đã giao việc).
      // Việc sửa nội dung phiếu nháp được xử lý bằng cách xoá + tạo lại (create/delete ở trên).
      allow update: if isAdmin()
        && resource.data.status == "draft"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        && request.resource.data.status == "dispatched";

      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      // Admin đọc tất cả task; nhân viên chỉ đọc task được giao cho chính mình.
      allow read: if isAdmin()
        || (signedIn() && resource.data.assignedToUid == request.auth.uid);

      // Chỉ Admin được giao việc. Cho phép tạo ở trạng thái "draft" (chưa giao việc,
      // thông tin có thể chưa đầy đủ) hoặc "doing" (đã giao việc chính thức, bắt đầu đếm giờ).
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "id",
          "title",
          "description",
          "taskDate",
          "assignedToUid",
          "assignedToName",
          "assignedByUid",
          "assignedByName",
          "workOrderId",
          "workOrderName",
          "workOrderTaskCount",
          "rowIndex",
          "createdAt",
          "deadlineMinutes",
          "deadlineAt",
          "dispatchedAt",
          "queueStartAt",
          "pauseStartedAt",
          "remainingMsAtPause",
          "accumulatedWorkedMs",
          "submittedAt",
          "approvedAt",
          "status",
          "actualMinutes",
          "resultType",
          "differenceMinutes",
          "differencePercent",
          "photoRequired",
          "requiredPhotoCount",
          "photos",
          "photoCount",
          "lastPhotoUploadedAt"
        ])
        && request.resource.data.id == taskId
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.taskDate is string
        && request.resource.data.assignedToUid is string
        && (
          request.resource.data.assignedToUid == ""
          || (
            exists(userDoc(request.resource.data.assignedToUid))
            && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
          )
        )
        && request.resource.data.assignedToName is string
        && request.resource.data.assignedByUid == request.auth.uid
        && request.resource.data.assignedByName is string
        && request.resource.data.workOrderId is string
        && request.resource.data.workOrderId.size() > 0
        && request.resource.data.workOrderName is string
        && request.resource.data.workOrderName.size() > 0
        && request.resource.data.workOrderTaskCount is int
        && request.resource.data.workOrderTaskCount > 0
        && request.resource.data.workOrderTaskCount <= 500
        && request.resource.data.rowIndex is int
        && request.resource.data.rowIndex >= 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.deadlineMinutes is int
        && request.resource.data.deadlineMinutes >= 0
        && request.resource.data.deadlineMinutes <= 10080
        && request.resource.data.accumulatedWorkedMs is int
        && request.resource.data.accumulatedWorkedMs >= 0
        && (
          request.resource.data.remainingMsAtPause == null
          || (request.resource.data.remainingMsAtPause is int && request.resource.data.remainingMsAtPause >= 0)
        )
        && (
          request.resource.data.pauseStartedAt == null
          || request.resource.data.pauseStartedAt == request.time
        )
        && request.resource.data.submittedAt == null
        && request.resource.data.approvedAt == null
        && request.resource.data.actualMinutes == null
        && request.resource.data.resultType == null
        && request.resource.data.differenceMinutes == null
        && request.resource.data.differencePercent == null
        && request.resource.data.photoRequired is bool
        && request.resource.data.requiredPhotoCount is int
        && request.resource.data.requiredPhotoCount >= 0
        && request.resource.data.requiredPhotoCount <= 100
        && (
          !request.resource.data.photoRequired
          || request.resource.data.requiredPhotoCount > 0
        )
        && request.resource.data.photos is list
        && request.resource.data.photos.size() == 0
        && request.resource.data.photoCount is int
        && request.resource.data.photoCount == 0
        && request.resource.data.lastPhotoUploadedAt == null
        && (
          (
            request.resource.data.status == "draft"
            && request.resource.data.deadlineAt == null
            && request.resource.data.dispatchedAt == null
            && request.resource.data.queueStartAt == null
            && request.resource.data.pauseStartedAt == null
            && request.resource.data.remainingMsAtPause == null
          )
          || (
            request.resource.data.status == "waiting_assignee"
            && request.resource.data.title.size() > 0
            && request.resource.data.assignedToUid == ""
            && request.resource.data.assignedToName == ""
            && request.resource.data.deadlineMinutes > 0
            && request.resource.data.deadlineAt == null
            && request.resource.data.dispatchedAt == null
            && request.resource.data.queueStartAt == null
            && request.resource.data.pauseStartedAt == request.time
            && request.resource.data.remainingMsAtPause == null
          )
          || (
            request.resource.data.status == "doing"
            && request.resource.data.title.size() > 0
            && request.resource.data.assignedToUid != ""
            && request.resource.data.deadlineMinutes > 0
            && isValidQueueStartAt(request.resource.data.queueStartAt)
            && request.resource.data.deadlineAt is timestamp
            && request.resource.data.deadlineAt >= request.resource.data.queueStartAt
            && request.resource.data.dispatchedAt == request.time
            && request.resource.data.pauseStartedAt == null
            && request.resource.data.remainingMsAtPause == null
          )
        );

      // Nhân viên được đăng hình báo cáo cho task đang làm của chính mình.
      // Ảnh thật lưu ở Firebase Storage; Firestore chỉ lưu metadata + số lượng.
      allow update: if signedIn()
        && resource.data.assignedToUid == request.auth.uid
        && resource.data.status in ["doing", "redo", "overdue"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["photos", "photoCount", "lastPhotoUploadedAt"])
        && request.resource.data.photos is list
        && request.resource.data.photos.size() <= 200
        && request.resource.data.photoCount is int
        && request.resource.data.photoCount == request.resource.data.photos.size()
        && (!resource.data.keys().hasAny(["photos"]) || request.resource.data.photos.size() >= resource.data.photos.size())
        && (!resource.data.keys().hasAny(["photoCount"]) || request.resource.data.photoCount >= resource.data.photoCount)
        && request.resource.data.lastPhotoUploadedAt == request.time;

      // Nhân viên chỉ được bấm Hoàn thành task của chính mình.
      // Không được tự chuyển sang completed, không được sửa nội dung/deadline/người nhận.
      allow update: if signedIn()
        && resource.data.assignedToUid == request.auth.uid
        && resource.data.status in ["doing", "redo", "overdue"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "submittedAt"])
        && request.resource.data.status == "submitted"
        && request.resource.data.submittedAt == request.time
        && (
          !resource.data.photoRequired
          || (
            resource.data.photoCount is int
            && resource.data.requiredPhotoCount is int
            && resource.data.photoCount >= resource.data.requiredPhotoCount
          )
        );

      // Admin bấm "Giao việc" cho 1 phiếu đang ở trạng thái nháp: chuyển task draft -> doing,
      // bắt đầu tính hạn hoàn thành từ thời điểm này (có thể xếp hàng nếu nhân viên còn việc khác).
      allow update: if isAdmin()
        && resource.data.status == "draft"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "dispatchedAt", "queueStartAt", "deadlineAt"])
        && request.resource.data.status == "doing"
        && request.resource.data.assignedToUid != ""
        && request.resource.data.deadlineMinutes > 0
        && request.resource.data.dispatchedAt == request.time
        && isValidQueueStartAt(request.resource.data.queueStartAt)
        && request.resource.data.deadlineAt is timestamp
        && request.resource.data.deadlineAt > request.resource.data.queueStartAt;

      // Admin đổi nhân viên phụ trách task đang làm/đang chờ đến lượt/quá hạn/yêu cầu làm lại.
      // - Nếu task đang chạy: chỉ đổi assignedToUid/assignedToName, giữ nguyên toàn bộ mốc thời gian.
      // - Nếu task đang chờ đến lượt (queueStartAt > request.time): đổi người và cho task bắt đầu ngay như mới giao.
      allow update: if isAdmin()
        && resource.data.status in ["doing", "redo", "overdue"]
        && request.resource.data.id == resource.data.id
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.assignedToUid != resource.data.assignedToUid
        && exists(userDoc(request.resource.data.assignedToUid))
        && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
        && request.resource.data.assignedToName is string
        && request.resource.data.assignedToName.size() > 0
        && request.resource.data.deadlineMinutes == resource.data.deadlineMinutes
        && request.resource.data.assigneeChangeHistory is list
        && request.resource.data.assigneeChangeHistory.size() <= 200
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["assignedToUid", "assignedToName", "assigneeChangeHistory"])
            && request.resource.data.status == resource.data.status
            && request.resource.data.dispatchedAt == resource.data.dispatchedAt
            && request.resource.data.queueStartAt == resource.data.queueStartAt
            && request.resource.data.deadlineAt == resource.data.deadlineAt
          )
          ||
          (
            resource.data.queueStartAt is timestamp
            && resource.data.queueStartAt > request.time
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "assignedToUid",
              "assignedToName",
              "assigneeChangeHistory",
              "status",
              "dispatchedAt",
              "queueStartAt",
              "deadlineAt"
            ])
            && request.resource.data.status == "doing"
            && request.resource.data.dispatchedAt == request.time
            && isValidQueueStartAt(request.resource.data.queueStartAt)
            && request.resource.data.deadlineAt is timestamp
            && request.resource.data.deadlineAt > request.resource.data.queueStartAt
          )
        );

      // Admin được cập nhật nhân viên phụ trách, chuyển về Chờ chọn người,
      // tiếp tục giao lại task đang tạm dừng, thêm giờ, duyệt, yêu cầu làm lại
      // và đồng bộ trạng thái. Các ràng buộc cơ bản bên dưới giữ nguyên id/người giao
      // và chỉ cho assignedToUid rỗng hoặc trỏ tới user nhân viên hợp lệ.
      allow update: if isAdmin()
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.workOrderId == resource.data.workOrderId
        && request.resource.data.workOrderName == resource.data.workOrderName
        && request.resource.data.assignedToUid is string
        && (
          request.resource.data.assignedToUid == ""
          || (
            exists(userDoc(request.resource.data.assignedToUid))
            && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
          )
        )
        && request.resource.data.assignedToName is string
        && request.resource.data.deadlineMinutes is int
        && request.resource.data.deadlineMinutes >= 0
        && request.resource.data.deadlineMinutes <= 10080
        && isValidTaskStatus(request.resource.data.status);

      // Admin được duyệt hoàn thành, yêu cầu làm lại, hoặc đánh dấu quá hạn.
      allow update: if isAdmin()
        && request.resource.data.id == resource.data.id
        && request.resource.data.assignedToUid == resource.data.assignedToUid
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && isValidTaskStatus(request.resource.data.status);

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Mỗi người chỉ đọc thông báo gửi cho chính mình. Admin có thể đọc tất cả để hỗ trợ kiểm tra lỗi.
      allow read: if isAdmin()
        || (signedIn() && resource.data.recipientUid == request.auth.uid);

      // Admin tạo thông báo khi giao việc, xác nhận hoàn thành, yêu cầu làm lại.
      // Nhân viên chỉ được tạo thông báo "đã báo hoàn thành" gửi về đúng Admin giao việc.
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "id",
          "recipientUid",
          "type",
          "title",
          "message",
          "taskId",
          "taskTitle",
          "actorUid",
          "actorName",
          "createdAt",
          "readAt"
        ])
        && request.resource.data.id == notificationId
        && request.resource.data.recipientUid is string
        && exists(userDoc(request.resource.data.recipientUid))
        && isValidNotificationType(request.resource.data.type)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.taskId is string
        && exists(taskDoc(request.resource.data.taskId))
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.readAt == null
        && (
          isAdmin()
          || (
            request.resource.data.type == "task_submitted"
            && get(taskDoc(request.resource.data.taskId)).data.assignedToUid == request.auth.uid
            && get(taskDoc(request.resource.data.taskId)).data.assignedByUid == request.resource.data.recipientUid
          )
        );

      // Người nhận được đánh dấu thông báo của mình là đã đọc.
      allow update: if signedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"])
        && request.resource.data.readAt == request.time;

      allow delete: if isAdmin()
        || (signedIn() && resource.data.recipientUid == request.auth.uid);
    }

    match /timeExtensionReasons/{reasonId} {
      // Admin quản lý danh sách mục đích thêm giờ; nhân viên có thể đọc để hiển thị thống nhất nếu cần.
      allow read: if signedIn();

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "id",
          "name",
          "active",
          "createdByUid",
          "createdByName",
          "createdAt"
        ])
        && request.resource.data.id == reasonId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.active is bool
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdAt == request.time;

      allow update, delete: if isAdmin();
    }


  }
}
