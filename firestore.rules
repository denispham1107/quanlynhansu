rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userDoc(request.auth.uid))
        && get(userDoc(request.auth.uid)).data.role == "admin";
    }

    function isSupervisor() {
      return signedIn()
        && exists(userDoc(request.auth.uid))
        && get(userDoc(request.auth.uid)).data.role == "supervisor";
    }

    function isManagement() {
      return isAdmin() || isSupervisor();
    }

    function hasPermission(permissionKey) {
      return isAdmin()
        || (
          isSupervisor()
          && get(userDoc(request.auth.uid)).data.keys().hasAny(["permissions"])
          && get(userDoc(request.auth.uid)).data.permissions is map
          && get(userDoc(request.auth.uid)).data.permissions.get(permissionKey, false) == true
        );
    }

    function canCreateManagementNotification() {
      return hasPermission("createWorkOrder")
        || hasPermission("editWorkOrder")
        || hasPermission("dispatchWorkOrder")
        || hasPermission("reviewTasks")
        || hasPermission("reassignTasks")
        || hasPermission("extendTaskTime")
        || hasPermission("manageEmployeeAccounts")
        || hasPermission("importData");
    }

    function isValidRole(role) {
      return role in ["admin", "supervisor", "employee"];
    }

    function isValidTaskStatus(status) {
      return status in ["waiting_assignee", "doing", "lunch_break", "hotel", "submitted", "completed", "redo", "overdue"];
    }

    function dataIsLunchBreak(data) {
      return data.keys().hasAny(["isLunchBreak"]) && data.isLunchBreak == true;
    }

    function dataIsHotel(data) {
      return data.keys().hasAny(["isHotel"]) && data.isHotel == true;
    }

    function dataIsNormalWork(data) {
      return !dataIsLunchBreak(data) && !dataIsHotel(data);
    }

    function taskDoc(taskId) {
      return /databases/$(database)/documents/tasks/$(taskId);
    }

    function workOrderDoc(workOrderId) {
      return /databases/$(database)/documents/workOrders/$(workOrderId);
    }

    // Cho phép các task cũ tạo trước khi có tính năng bắt buộc đăng hình
    // vẫn được nhân viên bấm Hoàn thành nếu chưa có field photoRequired.
    function isTaskPhotoRequirementSatisfied(taskData) {
      return !taskData.keys().hasAny(["photoRequired"])
        || taskData.photoRequired == false
        || (
          taskData.photoRequired == true
          && taskData.keys().hasAll(["photoCount", "requiredPhotoCount"])
          && taskData.photoCount is int
          && taskData.requiredPhotoCount is int
          && taskData.photoCount >= taskData.requiredPhotoCount
        );
    }

    // Client tạo queueStartAt bằng thời gian trên máy người dùng, còn request.time
    // là thời gian server Firestore khi commit. Hai mốc này có thể lệch vài giây,
    // nếu bắt queueStartAt >= request.time tuyệt đối sẽ dễ bị lỗi
    // "Missing or insufficient permissions" khi tạo/giao việc ngay lập tức.
    function isValidQueueStartAt(value) {
      return value is timestamp
        && value >= request.time - duration.value(2, "m");
    }

    function isValidNotificationType(type) {
      return type in [
        "task_assigned",
        "task_assigned_admin",
        "task_submitted",
        "task_approved",
        "task_approved_admin",
        "task_redo",
        "task_time_extended",
        "task_time_extended_admin",
        "task_reassigned",
        "task_reassigned_removed",
        "task_reassigned_admin",
        "work_order_draft_saved"
      ];
    }

    match /users/{userId} {
      // Admin đọc tất cả user; nhân viên chỉ đọc hồ sơ của chính mình.
      allow read: if isManagement() || (signedIn() && request.auth.uid == userId);

      // Admin được nhập/khôi phục dữ liệu users từ file backup JSON.
      allow create, update: if isAdmin();

      // Admin tạo hồ sơ user sau khi tạo tài khoản bằng Firebase Auth.
      // Admin đầu tiên nên tạo thủ công theo hướng dẫn, trước khi bật rules chặt này.
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(["uid", "name", "email", "role", "createdByUid", "createdAt"])
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && isValidRole(request.resource.data.role)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdAt == request.time;

      // Chỉ Admin được sửa user. Không cho đổi uid/email gốc qua client.
      allow update: if isAdmin()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role in ["admin", "supervisor", "employee"];

      // Giám sát có quyền Quản lý tài khoản chỉ được tạo hồ sơ Nhân viên thường.
      // Không được tạo Admin/Giám sát và không được tự thêm field phân quyền.
      allow create: if hasPermission("manageEmployeeAccounts")
        && !isAdmin()
        && request.resource.data.keys().hasOnly(["uid", "name", "email", "role", "createdByUid", "createdAt"])
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && request.resource.data.role == "employee"
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdAt == request.time;

      // Có thể xoá hồ sơ nhân viên, nhưng không cho người quản lý tự xoá chính mình.
      // Giám sát chỉ được xoá tài khoản Nhân viên, không được xoá Admin hoặc Giám sát khác.
      allow delete: if request.auth.uid != userId
        && (
          isAdmin()
          || (hasPermission("manageEmployeeAccounts") && resource.data.role == "employee")
        );
    }

    match /workOrders/{workOrderId} {
      // Admin đọc toàn bộ phiếu. Nhân viên cũng được đọc metadata phiếu
      // (tên phiếu, tổng số công việc) để tiêu đề phiếu hiển thị giống trang Admin.
      allow read: if isAdmin() || signedIn();

      // Admin được nhập/khôi phục dữ liệu phiếu từ file backup JSON.
      allow create, update: if isAdmin();

      allow create: if (hasPermission("createWorkOrder") || hasPermission("editWorkOrder") || hasPermission("importData"))
        && request.resource.data.keys().hasOnly([
          "id",
          "name",
          "createdByUid",
          "createdByName",
          "createdAt",
          "taskCount",
          "status"
        ])
        && request.resource.data.id == workOrderId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.taskCount is int
        && request.resource.data.taskCount > 0
        && request.resource.data.status in ["draft", "dispatched"]
        && (request.resource.data.status == "draft" || hasPermission("dispatchWorkOrder"));

      // Chỉ cho phép chuyển từ "draft" (chưa giao việc) sang "dispatched" (đã giao việc).
      // Việc sửa nội dung phiếu nháp được xử lý bằng cách xoá + tạo lại (create/delete ở trên).
      allow update: if isAdmin()
        && resource.data.status == "draft"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        && request.resource.data.status == "dispatched";

      // Giám sát có quyền Giao Phiếu chỉ được chuyển Phiếu nháp sang đã giao.
      allow update: if hasPermission("dispatchWorkOrder")
        && resource.data.status == "draft"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        && request.resource.data.status == "dispatched";

      // Khi xoá nhân viên, cập nhật lại số lượng công việc còn lại trong Phiếu.
      allow update: if hasPermission("manageEmployeeAccounts")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["taskCount"])
        && request.resource.data.taskCount is int
        && request.resource.data.taskCount > 0;

      // Quyền Nhập dữ liệu được ghi đè metadata Phiếu từ file sao lưu.
      allow update: if hasPermission("importData");

      allow delete: if isAdmin()
        || hasPermission("deleteWorkOrder")
        || (hasPermission("editWorkOrder") && resource.data.status == "draft")
        || hasPermission("deleteAllWorkOrders")
        || hasPermission("manageEmployeeAccounts")
        || hasPermission("importData");
    }

    match /tasks/{taskId} {
      // Admin đọc tất cả task; nhân viên chỉ đọc task được giao cho chính mình.
      allow read: if isManagement()
        || (signedIn() && resource.data.assignedToUid == request.auth.uid);

      // Admin được nhập/khôi phục dữ liệu task từ file backup JSON.
      allow create, update: if isAdmin();

      // Chỉ Admin được giao việc. Cho phép tạo ở trạng thái "draft" (chưa giao việc,
      // thông tin có thể chưa đầy đủ) hoặc "doing" (đã giao việc chính thức, bắt đầu đếm giờ).
      allow create: if (hasPermission("createWorkOrder") || hasPermission("editWorkOrder") || hasPermission("importData"))
        && request.resource.data.keys().hasOnly([
          "id",
          "title",
          "description",
          "taskDate",
          "assignedToUid",
          "assignedToName",
          "assignedByUid",
          "assignedByName",
          "workOrderId",
          "workOrderName",
          "workOrderTaskCount",
          "rowIndex",
          "createdAt",
          "deadlineMinutes",
          "isLunchBreak",
          "isHotel",
          "hotelPetCount",
          "hotelAllowedMinutes",
          "deadlineAt",
          "dispatchedAt",
          "queueStartAt",
          "pauseStartedAt",
          "remainingMsAtPause",
          "accumulatedWorkedMs",
          "submittedAt",
          "approvedAt",
          "status",
          "actualMinutes",
          "resultType",
          "differenceMinutes",
          "differencePercent",
          "photoRequired",
          "requiredPhotoCount",
          "photos",
          "photoCount",
          "lastPhotoUploadedAt"
        ])
        && request.resource.data.id == taskId
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.taskDate is string
        && request.resource.data.assignedToUid is string
        && (
          request.resource.data.assignedToUid == ""
          || (
            exists(userDoc(request.resource.data.assignedToUid))
            && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
          )
        )
        && request.resource.data.assignedToName is string
        && request.resource.data.assignedByUid == request.auth.uid
        && request.resource.data.assignedByName is string
        && request.resource.data.workOrderId is string
        && request.resource.data.workOrderId.size() > 0
        && request.resource.data.workOrderName is string
        && request.resource.data.workOrderName.size() > 0
        && request.resource.data.workOrderTaskCount is int
        && request.resource.data.workOrderTaskCount > 0
        && request.resource.data.workOrderTaskCount <= 500
        && request.resource.data.rowIndex is int
        && request.resource.data.rowIndex >= 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.deadlineMinutes is int
        && request.resource.data.deadlineMinutes >= 0
        && request.resource.data.deadlineMinutes <= 10080
        && request.resource.data.isLunchBreak is bool
        && request.resource.data.isHotel is bool
        && !(request.resource.data.isLunchBreak == true && request.resource.data.isHotel == true)
        && request.resource.data.hotelPetCount is int
        && request.resource.data.hotelPetCount >= 0
        && request.resource.data.hotelPetCount <= 500
        && request.resource.data.hotelAllowedMinutes is int
        && request.resource.data.hotelAllowedMinutes >= 0
        && request.resource.data.hotelAllowedMinutes <= 10080
        && (
          request.resource.data.isHotel == true
          || (request.resource.data.hotelPetCount == 0
            && request.resource.data.hotelAllowedMinutes == 0)
        )
        && (
          !request.resource.data.isLunchBreak
          || (request.resource.data.deadlineMinutes > 0 && request.resource.data.deadlineMinutes <= 30)
        )
        && request.resource.data.accumulatedWorkedMs is int
        && request.resource.data.accumulatedWorkedMs >= 0
        && (
          request.resource.data.remainingMsAtPause == null
          || (request.resource.data.remainingMsAtPause is int && request.resource.data.remainingMsAtPause >= 0)
        )
        && (
          request.resource.data.pauseStartedAt == null
          || request.resource.data.pauseStartedAt == request.time
        )
        && request.resource.data.submittedAt == null
        && request.resource.data.approvedAt == null
        && request.resource.data.actualMinutes == null
        && request.resource.data.resultType == null
        && request.resource.data.differenceMinutes == null
        && request.resource.data.differencePercent == null
        && request.resource.data.photoRequired is bool
        && request.resource.data.requiredPhotoCount is int
        && request.resource.data.requiredPhotoCount >= 0
        && request.resource.data.requiredPhotoCount <= 100
        && (
          !request.resource.data.photoRequired
          || request.resource.data.requiredPhotoCount > 0
        )
        && request.resource.data.photos is list
        && request.resource.data.photos.size() == 0
        && request.resource.data.photoCount is int
        && request.resource.data.photoCount == 0
        && request.resource.data.lastPhotoUploadedAt == null
        && (request.resource.data.status == "draft" || hasPermission("dispatchWorkOrder"))
        && (
          (
            request.resource.data.status == "draft"
            && request.resource.data.deadlineAt == null
            && request.resource.data.dispatchedAt == null
            && request.resource.data.queueStartAt == null
            && request.resource.data.pauseStartedAt == null
            && request.resource.data.remainingMsAtPause == null
          )
          || (
            request.resource.data.status == "waiting_assignee"
            && request.resource.data.title.size() > 0
            && request.resource.data.assignedToUid == ""
            && request.resource.data.assignedToName == ""
            && request.resource.data.deadlineMinutes > 0
            && request.resource.data.deadlineAt == null
            && request.resource.data.dispatchedAt == null
            && request.resource.data.queueStartAt == null
            && request.resource.data.pauseStartedAt == request.time
            && request.resource.data.remainingMsAtPause == null
          )
          || (
            request.resource.data.status in ["doing", "lunch_break", "hotel"]
            && (
              (dataIsLunchBreak(request.resource.data) && request.resource.data.status == "lunch_break")
              || (dataIsHotel(request.resource.data) && request.resource.data.status == "hotel")
              || (dataIsNormalWork(request.resource.data) && request.resource.data.status == "doing")
            )
            && request.resource.data.title.size() > 0
            && request.resource.data.assignedToUid != ""
            && request.resource.data.deadlineMinutes > 0
            && isValidQueueStartAt(request.resource.data.queueStartAt)
            && request.resource.data.deadlineAt is timestamp
            && request.resource.data.deadlineAt >= request.resource.data.queueStartAt
            && request.resource.data.dispatchedAt == request.time
            && request.resource.data.pauseStartedAt == null
            && request.resource.data.remainingMsAtPause == null
          )
        );

      // Nhân viên được đăng hình báo cáo cho task đang làm của chính mình.
      // Ảnh thật lưu ở Firebase Storage; Firestore chỉ lưu metadata + số lượng.
      allow update: if signedIn()
        && resource.data.assignedToUid == request.auth.uid
        && resource.data.status in ["doing", "lunch_break", "hotel", "redo", "overdue"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["photos", "photoCount", "lastPhotoUploadedAt"])
        && request.resource.data.photos is list
        && request.resource.data.photos.size() <= 200
        && request.resource.data.photoCount is int
        && request.resource.data.photoCount == request.resource.data.photos.size()
        && (!resource.data.keys().hasAny(["photos"]) || request.resource.data.photos.size() >= resource.data.photos.size())
        && (!resource.data.keys().hasAny(["photoCount"]) || request.resource.data.photoCount >= resource.data.photoCount)
        && request.resource.data.lastPhotoUploadedAt == request.time;

      // Nhân viên chỉ được bấm Hoàn thành task của chính mình.
      // Không được tự chuyển sang completed, không được sửa nội dung/deadline/người nhận.
      allow update: if signedIn()
        && resource.data.assignedToUid == request.auth.uid
        && resource.data.status in ["doing", "lunch_break", "hotel", "redo", "overdue"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "submittedAt"])
        && request.resource.data.status == "submitted"
        && request.resource.data.submittedAt == request.time
        && isTaskPhotoRequirementSatisfied(resource.data);

      // Admin bấm "Giao việc" cho 1 phiếu đang ở trạng thái nháp: chuyển task draft -> doing,
      // bắt đầu tính hạn hoàn thành từ thời điểm này (có thể xếp hàng nếu nhân viên còn việc khác).
      allow update: if isAdmin()
        && resource.data.status == "draft"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "dispatchedAt", "queueStartAt", "deadlineAt"])
        && request.resource.data.status in ["doing", "lunch_break", "hotel"]
        && (
          (dataIsLunchBreak(resource.data) && request.resource.data.status == "lunch_break")
          || (dataIsHotel(resource.data) && request.resource.data.status == "hotel")
          || (dataIsNormalWork(resource.data) && request.resource.data.status == "doing")
        )
        && request.resource.data.assignedToUid != ""
        && request.resource.data.deadlineMinutes > 0
        && request.resource.data.dispatchedAt == request.time
        && isValidQueueStartAt(request.resource.data.queueStartAt)
        && request.resource.data.deadlineAt is timestamp
        && request.resource.data.deadlineAt > request.resource.data.queueStartAt;

      // Admin đổi nhân viên phụ trách task đang làm/đang chờ đến lượt/quá hạn/yêu cầu làm lại.
      // - Nếu task đang chạy: chỉ đổi assignedToUid/assignedToName, giữ nguyên toàn bộ mốc thời gian.
      // - Nếu task đang chờ đến lượt (queueStartAt > request.time): đổi người và cho task bắt đầu ngay như mới giao.
      allow update: if isAdmin()
        && resource.data.status in ["doing", "lunch_break", "hotel", "redo", "overdue"]
        && request.resource.data.id == resource.data.id
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.assignedToUid != resource.data.assignedToUid
        && exists(userDoc(request.resource.data.assignedToUid))
        && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
        && request.resource.data.assignedToName is string
        && request.resource.data.assignedToName.size() > 0
        && request.resource.data.deadlineMinutes == resource.data.deadlineMinutes
        && request.resource.data.assigneeChangeHistory is list
        && request.resource.data.assigneeChangeHistory.size() <= 200
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["assignedToUid", "assignedToName", "assigneeChangeHistory"])
            && request.resource.data.status == resource.data.status
            && request.resource.data.dispatchedAt == resource.data.dispatchedAt
            && request.resource.data.queueStartAt == resource.data.queueStartAt
            && request.resource.data.deadlineAt == resource.data.deadlineAt
          )
          ||
          (
            resource.data.queueStartAt is timestamp
            && resource.data.queueStartAt > request.time
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "assignedToUid",
              "assignedToName",
              "assigneeChangeHistory",
              "status",
              "dispatchedAt",
              "queueStartAt",
              "deadlineAt"
            ])
            && request.resource.data.status in ["doing", "lunch_break", "hotel"]
            && (
              (dataIsLunchBreak(resource.data) && request.resource.data.status == "lunch_break")
              || (dataIsHotel(resource.data) && request.resource.data.status == "hotel")
              || (dataIsNormalWork(resource.data) && request.resource.data.status == "doing")
            )
            && request.resource.data.dispatchedAt == request.time
            && isValidQueueStartAt(request.resource.data.queueStartAt)
            && request.resource.data.deadlineAt is timestamp
            && request.resource.data.deadlineAt > request.resource.data.queueStartAt
          )
        );

      // Admin được cập nhật nhân viên phụ trách, chuyển về Chờ chọn người,
      // tiếp tục giao lại task đang tạm dừng, thêm giờ, duyệt, yêu cầu làm lại
      // và đồng bộ trạng thái. Các ràng buộc cơ bản bên dưới giữ nguyên id/người giao
      // và chỉ cho assignedToUid rỗng hoặc trỏ tới user nhân viên hợp lệ.
      allow update: if isAdmin()
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.workOrderId == resource.data.workOrderId
        && request.resource.data.workOrderName == resource.data.workOrderName
        && request.resource.data.assignedToUid is string
        && (
          request.resource.data.assignedToUid == ""
          || (
            exists(userDoc(request.resource.data.assignedToUid))
            && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
          )
        )
        && request.resource.data.assignedToName is string
        && request.resource.data.deadlineMinutes is int
        && request.resource.data.deadlineMinutes >= 0
        && request.resource.data.deadlineMinutes <= 10080
        && isValidTaskStatus(request.resource.data.status);

      // Admin được duyệt hoàn thành, yêu cầu làm lại, hoặc đánh dấu quá hạn.
      allow update: if isAdmin()
        && request.resource.data.id == resource.data.id
        && request.resource.data.assignedToUid == resource.data.assignedToUid
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && isValidTaskStatus(request.resource.data.status);

      // Giao task nháp: chỉ được thay đổi các field bắt đầu/xếp hàng thời gian.
      allow update: if hasPermission("dispatchWorkOrder")
        && resource.data.status == "draft"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "dispatchedAt",
          "queueStartAt",
          "deadlineAt",
          "pauseStartedAt",
          "remainingMsAtPause",
          "accumulatedWorkedMs"
        ])
        && request.resource.data.status in ["waiting_assignee", "doing", "lunch_break", "hotel"];

      // Đổi nhân viên, chuyển về Chờ chọn người hoặc bắt đầu lại task đang chờ.
      allow update: if hasPermission("reassignTasks")
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.workOrderId == resource.data.workOrderId
        && request.resource.data.workOrderName == resource.data.workOrderName
        && request.resource.data.deadlineMinutes == resource.data.deadlineMinutes
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "assignedToUid",
          "assignedToName",
          "status",
          "dispatchedAt",
          "queueStartAt",
          "deadlineAt",
          "pauseStartedAt",
          "remainingMsAtPause",
          "accumulatedWorkedMs",
          "assigneeChangeHistory"
        ])
        && request.resource.data.assignedToUid is string
        && (
          request.resource.data.assignedToUid == ""
          || (
            exists(userDoc(request.resource.data.assignedToUid))
            && get(userDoc(request.resource.data.assignedToUid)).data.role == "employee"
          )
        )
        && request.resource.data.assignedToName is string
        && isValidTaskStatus(request.resource.data.status);

      // Thêm giờ và lưu lịch sử thêm giờ.
      allow update: if hasPermission("extendTaskTime")
        && request.resource.data.id == resource.data.id
        && request.resource.data.assignedToUid == resource.data.assignedToUid
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "deadlineMinutes",
          "deadlineAt",
          "status",
          "timeExtensionCount",
          "timeExtensionTotalMinutes",
          "timeExtensions",
          "lastTimeExtendedAt",
          "lastTimeExtendedByUid",
          "lastTimeExtendedByName"
        ])
        && request.resource.data.deadlineMinutes is int
        && request.resource.data.deadlineMinutes >= resource.data.deadlineMinutes
        && request.resource.data.deadlineMinutes <= 10080
        && isValidTaskStatus(request.resource.data.status);

      // Duyệt hoàn thành, yêu cầu làm lại, kết thúc Nghỉ trưa và dồn lại hàng đợi.
      allow update: if hasPermission("reviewTasks")
        && request.resource.data.id == resource.data.id
        && request.resource.data.assignedToUid == resource.data.assignedToUid
        && request.resource.data.assignedByUid == resource.data.assignedByUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "submittedAt",
          "approvedAt",
          "actualMinutes",
          "resultType",
          "differenceMinutes",
          "differencePercent",
          "queueStartAt",
          "deadlineAt"
        ])
        && isValidTaskStatus(request.resource.data.status);

      // Chỉnh số lượng ảnh báo cáo bắt buộc.
      allow update: if hasPermission("managePhotoRequirements")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["photoRequired", "requiredPhotoCount"])
        && request.resource.data.photoRequired is bool
        && request.resource.data.requiredPhotoCount is int
        && request.resource.data.requiredPhotoCount >= 0
        && request.resource.data.requiredPhotoCount <= 100;

      // Xóa ảnh báo cáo: chỉ được cập nhật metadata ảnh, file thật do Storage Rules kiểm tra riêng.
      allow update: if hasPermission("deleteReportPhotos")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["photos", "photoCount", "lastPhotoUploadedAt"])
        && request.resource.data.photos is list
        && request.resource.data.photos.size() <= 200
        && request.resource.data.photoCount is int
        && request.resource.data.photoCount == request.resource.data.photos.size();

      // Xóa nhân viên có thể làm thay đổi thứ tự/số lượng task còn lại trong cùng Phiếu.
      allow update: if hasPermission("manageEmployeeAccounts")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["rowIndex", "workOrderTaskCount"])
        && request.resource.data.rowIndex is int
        && request.resource.data.rowIndex >= 0
        && request.resource.data.workOrderTaskCount is int
        && request.resource.data.workOrderTaskCount > 0;

      // Nhập dữ liệu có thể khôi phục toàn bộ field task, nhưng không cho phép qua collection users.
      allow update: if hasPermission("importData");

      allow delete: if isAdmin()
        || hasPermission("deleteWorkOrder")
        || (hasPermission("editWorkOrder") && resource.data.status == "draft")
        || hasPermission("deleteAllWorkOrders")
        || hasPermission("manageEmployeeAccounts")
        || hasPermission("importData");
    }

    match /notifications/{notificationId} {
      // Mỗi người chỉ đọc thông báo gửi cho chính mình. Admin có thể đọc tất cả để hỗ trợ kiểm tra lỗi.
      allow read: if isAdmin()
        || hasPermission("exportData")
        || hasPermission("deleteAllWorkOrders")
        || hasPermission("manageEmployeeAccounts")
        || hasPermission("importData")
        || (signedIn() && resource.data.recipientUid == request.auth.uid);

      // Admin được nhập/khôi phục thông báo từ file backup JSON.
      allow create, update: if isAdmin();

      // Admin tạo thông báo khi giao việc, xác nhận hoàn thành, yêu cầu làm lại.
      // Nhân viên chỉ được tạo thông báo "đã báo hoàn thành" gửi về đúng Admin giao việc.
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "id",
          "recipientUid",
          "type",
          "title",
          "message",
          "taskId",
          "taskTitle",
          "actorUid",
          "actorName",
          "createdAt",
          "readAt"
        ])
        && request.resource.data.id == notificationId
        && request.resource.data.recipientUid is string
        && exists(userDoc(request.resource.data.recipientUid))
        && isValidNotificationType(request.resource.data.type)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.taskId is string
        && exists(taskDoc(request.resource.data.taskId))
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.readAt == null
        && (
          canCreateManagementNotification()
          || (
            request.resource.data.type == "task_submitted"
            && get(taskDoc(request.resource.data.taskId)).data.assignedToUid == request.auth.uid
            && get(taskDoc(request.resource.data.taskId)).data.assignedByUid == request.resource.data.recipientUid
          )
        );

      // Người nhận được đánh dấu thông báo của mình là đã đọc.
      allow update: if signedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"])
        && request.resource.data.readAt == request.time;

      // Giám sát có quyền Nhập dữ liệu được khôi phục notification từ backup.
      allow create, update: if hasPermission("importData");

      allow delete: if isAdmin()
        || (signedIn() && resource.data.recipientUid == request.auth.uid)
        || hasPermission("deleteAllWorkOrders")
        || hasPermission("manageEmployeeAccounts")
        || hasPermission("importData");
    }


    match /hotelDailyReports/{reportId} {
      // Admin và Giám sát đều được xem kết quả Hotel.
      allow read: if isManagement();

      allow create, update: if isAdmin()
        || hasPermission("manageHotelReports")
        || hasPermission("manageEmployeeAccounts")
        || hasPermission("importData");

      allow delete: if isAdmin()
        || hasPermission("deleteAllWorkOrders")
        || hasPermission("importData");
    }

    match /workTemplates/{templateId} {
      // Admin quản lý danh sách công việc mẫu kèm thời gian hoàn thành.
      allow read: if isManagement();

      // Admin được nhập/khôi phục danh sách công việc mẫu từ file backup JSON.
      allow create, update: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "id",
          "name",
          "searchText",
          "deadlineMinutes",
          "createdByUid",
          "createdByName",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.id == templateId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.searchText is string
        && request.resource.data.searchText.size() > 0
        && request.resource.data.searchText.size() <= 160
        && request.resource.data.deadlineMinutes is int
        && request.resource.data.deadlineMinutes > 0
        && request.resource.data.deadlineMinutes <= 10080
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdByName.size() > 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == null;

      allow create, update, delete: if isAdmin()
        || hasPermission("manageWorkTemplates")
        || hasPermission("importData");
    }

    match /timeExtensionReasons/{reasonId} {
      // Admin quản lý danh sách mục đích thêm giờ; nhân viên có thể đọc để hiển thị thống nhất nếu cần.
      allow read: if signedIn();

      // Admin được nhập/khôi phục mục đích thêm giờ từ file backup JSON.
      allow create, update: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "id",
          "name",
          "active",
          "createdByUid",
          "createdByName",
          "createdAt"
        ])
        && request.resource.data.id == reasonId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.active is bool
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdAt == request.time;

      allow create, update, delete: if isAdmin()
        || hasPermission("extendTaskTime")
        || hasPermission("importData");
    }


  }
}
