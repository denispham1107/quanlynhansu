rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function taskDoc(taskId) {
      return firestore.get(/databases/(default)/documents/tasks/$(taskId));
    }

    function isAdmin() {
      return signedIn()
        && userDoc(request.auth.uid).data.role == "admin";
    }

    function isSupervisor() {
      return signedIn()
        && userDoc(request.auth.uid).data.role == "supervisor";
    }

    function isManagement() {
      return isAdmin() || isSupervisor();
    }

    function hasPermission(permissionKey) {
      return isAdmin()
        || (
          isSupervisor()
          && userDoc(request.auth.uid).data.keys().hasAny(["permissions"])
          && userDoc(request.auth.uid).data.permissions is map
          && userDoc(request.auth.uid).data.permissions.get(permissionKey, false) == true
        );
    }

    function isTaskAssignee(taskId) {
      return signedIn()
        && taskDoc(taskId).data.assignedToUid == request.auth.uid;
    }

    function canDeleteTaskPhoto(taskId) {
      return isAdmin()
        || hasPermission("deleteReportPhotos")
        || hasPermission("deleteWorkOrder")
        || hasPermission("deleteAllWorkOrders")
        || hasPermission("manageEmployeeAccounts")
        || (
          hasPermission("editWorkOrder")
          && taskDoc(taskId).data.status == "draft"
        );
    }

    match /task-work-photos/{ownerUid}/{rowId}/{fileName} {
      // Ảnh CV chỉ dành cho tài khoản quản lý. Nhân viên không được đăng hoặc sửa.
      allow read: if isManagement();
      allow create: if isManagement()
        && request.auth.uid == ownerUid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if isManagement();
    }

    match /task-photos/{taskId}/{fileName} {
      // Admin/Giám sát được xem toàn bộ ảnh báo cáo; nhân viên chỉ xem ảnh task của mình.
      allow read: if isManagement() || isTaskAssignee(taskId);

      allow create: if isTaskAssignee(taskId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow update: if false;
      allow delete: if canDeleteTaskPhoto(taskId);
    }
  }
}
